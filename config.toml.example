# stele configuration file
# Place at ~/.config/stele/config.toml or ./config.toml
# Or set STELE_CONFIG=/path/to/config.toml
#
# All values can be overridden via environment variables:
#   STELE_SERVER_HOST, STELE_SERVER_PORT,
#   STELE_FNS_BASE_URL, STELE_FNS_TOKEN, STELE_FNS_VAULT,
#   STELE_INDEX_DB_PATH

[server]
# Host to bind the HTTP server on
host = "127.0.0.1"

# Port for the HTTP server
port = 3000

[fns]
# Base URL of the FNS (vault) server
base_url = "http://localhost:3000"

# API token for FNS authentication
token = ""

# Vault name to use on the FNS server
vault = "default"

[index]
# Path to the SQLite database file
# Supports ~ expansion to the user's home directory
db_path = "~/.local/share/stele/index.db"
