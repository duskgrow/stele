        "createOnly":     {"type": "boolean", "required": false, "description": "If true, fail if note already exists"},
        "ctime":          {"type": "integer", "required": false, "description": "Creation timestamp (ms)"},
        "mtime":          {"type": "integer", "required": false, "description": "Modification timestamp (ms)"},
        "pathHash":       {"type": "string",  "required": false, "description": "Path hash"}
