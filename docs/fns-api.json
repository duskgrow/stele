  "authentication": {
    "method": "Custom header",
    "header_name": "token",
    "header_format": "token: <raw_token_value>",
    "notes": [
      "NOT 'Authorization: Bearer <token>' — the server expects a plain 'token' header",
      "The token is a JWT (HS256), signed with the key in FNS config security.auth-token-key",
      "Token payload contains uid, iat, exp fields",
      "Error code 307 = 'Not logged in' (no token or wrong format)",
      "Error code 308 = 'Session expired' (token parsed but server rejected)"
    ],
    "example": "curl -H 'token: eyJhbGci...' http://localhost:9000/api/note?vault=forge&path=hello.md"
  },

  "response_envelope": {
    "description": "All endpoints return this wrapper object",
    "schema": {
      "code": "integer — 1 = success, other values = error",
      "status": "boolean — true on success",
      "message": "string — 'Success' on success, error description on failure",
      "data": "any — the actual payload, type varies by endpoint",
      "context": "any — optional additional context",
      "vault": "any — optional vault info"
    },
    "success_example": {
      "code": 1,
      "status": true,
      "message": "Success",
      "data": {}
    },
    "error_examples": [
      {"code": 304, "message": "找不到API", "note": "Endpoint does not exist"},
      {"code": 305, "message": "Invalid Params", "note": "Missing or wrong parameters"},
      {"code": 307, "message": "Not logged in", "note": "No token or wrong format"},
      {"code": 308, "message": "Session expired", "note": "Token rejected by server"},
      {"code": 430, "message": "Note does not exist", "note": "Path correct but file missing"}
    ],
    "verified_live": true,
    "verified_success_code": 1
  },

