  "stele_vs_fns_comparison": {
    "_note": "Concrete differences between what stele implements and what FNS actually provides",

    "authentication": {
      "stele_uses": "Authorization: Bearer <token>",
      "fns_expects": "token: <raw_token>",
      "impact": "All requests rejected with code 307 'Not logged in'"
    },

    "success_code": {
      "stele_checks": "code == 0",
      "fns_returns": "code == 1",
      "impact": "Every successful API response parsed as error"
    },

    "get_note_url": {
      "stele_uses": "GET /api/v1/note/{vault}/{path}",
      "fns_expects": "GET /api/note?vault={vault}&path={path}",
      "impact": "404 or 304 — endpoint not found"
    },

    "get_note_response": {
      "stele_expects": "data is a raw markdown string",
      "fns_returns": "data is NoteWithFileLinksResponse object with .content field",
      "impact": "v.as_str() fails — cannot extract content from object"
    },

    "put_note_url": {
      "stele_uses": "PUT /api/v1/note/{vault}/{path} with raw markdown body",
      "fns_expects": "POST /api/note with JSON body {vault, path, content, ...}",
      "impact": "Wrong method (PUT vs POST) + wrong body format (raw vs JSON)"
    },

    "append_note_url": {
      "stele_uses": "POST /api/v1/note/{vault}/{path}/append with raw body",
      "fns_expects": "POST /api/note/append with JSON body {vault, path, content}",
      "impact": "Wrong URL structure + wrong body format"
    },

    "delete_note_url": {
      "stele_uses": "DELETE /api/v1/note/{vault}/{path}",
      "fns_expects": "DELETE /api/note?vault={vault}&path={path}",
      "impact": "404 — endpoint not found"
    },

    "list_notes_url": {
      "stele_uses": "GET /api/v1/note/{vault}/{dir}",
      "fns_expects": "GET /api/folder/notes?vault={vault}&path={dir}",
      "impact": "Completely different endpoint path"
    },

    "list_notes_response": {
      "stele_expects": "data is Vec<String> of filenames",
      "fns_returns": "data is {list: NoteDTO[], pager: {page, pageSize, totalRows}}",
      "impact": "Deserialization fails — wrong type + nested structure"
    },

    "list_folders_url": {
      "stele_uses": "GET /api/v1/folder/{vault}/{dir}",
      "fns_expects": "GET /api/folders?vault={vault}&path={dir}",
      "impact": "Wrong URL structure"
    },

    "list_folders_response": {
      "stele_expects": "data is Vec<String> of folder names",
      "fns_returns": "data is Vec<FolderDTO> with {path, pathHash, ctime, mtime, ...}",
      "impact": "Deserialization fails — objects vs strings"
    }
  },

  "available_but_unused_fns_endpoints": {
    "_note": "FNS provides these endpoints that stele doesn't use but could benefit from",

    "GET /api/note/backlinks": "Server-side backlink lookup — FNS already maintains a link graph",
    "GET /api/note/outlinks": "Server-side outgoing link lookup",
    "POST /api/note/prepend": "Prepend content to beginning of note",
    "POST /api/note/replace": "Find and replace within note content",
    "PATCH /api/note/frontmatter": "Update only YAML frontmatter without touching body",
    "POST /api/note/rename": "Rename/move a note",
    "GET /api/notes": "List all notes across entire vault with keyword search and pagination",
    "GET /api/note/histories": "Note version history",
    "PUT /api/note/history/restore": "Restore note from previous version",
    "GET /api/folder/tree": "Full directory tree with nested children"
  }
}
